        <mxCell id="5WDIMVf6dm-oXFQrB_wC-53" value="&lt;p style=&quot;margin:0px;margin-top:4px;text-align:center;text-decoration:underline;&quot;&gt;&lt;b&gt;ENUM AttributeDataType : uint6&lt;/b&gt;&lt;/p&gt;&lt;hr size=&quot;1&quot; style=&quot;border-style:solid;&quot;&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;bool&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;int&lt;br&gt;int64&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;float&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;double&lt;br&gt;iVec2&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;iVec3&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;iVec4&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;fVec2&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;fVec3&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;fVec4&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;dVec2&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;dVec3&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;dVec4&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;quaternion&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;color&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;matrix4x4&lt;/p&gt;&lt;p style=&quot;margin:0px;margin-left:8px;&quot;&gt;custom&lt;/p&gt;" style="verticalAlign=top;align=left;overflow=fill;html=1;whiteSpace=wrap;" parent="1" vertex="1">
          <mxGeometry x="1380" y="730" width="290" height="310" as="geometry" />
        </mxCell>
